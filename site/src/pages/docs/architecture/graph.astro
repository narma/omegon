---
import Docs from "../../../layouts/Docs.astro";
import { readFileSync, existsSync } from "node:fs";
import { join } from "node:path";

// Load pre-generated SVG from build script
const svgPath = join(process.cwd(), "public", "design-tree.svg");
const svgContent = existsSync(svgPath) ? readFileSync(svgPath, "utf-8") : null;
---

<Docs title="Design Graph" description="Force-directed visualization of omegon's design tree — every architectural decision from initial fork through the current state.">
  <h1>Design Graph</h1>
  <p>This is a static rendering of omegon's design exploration tree — every architectural decision from initial fork through the current state. Node count grows with each design session; the legend below reflects the most recent build.</p>

  <div class="graph-container">
    {svgContent ? <Fragment set:html={svgContent} /> : <p class="graph-placeholder">Graph SVG not generated. Run <code>npm run build</code> in <code>site/</code> to generate.</p>}
  </div>

  <h2>Legend</h2>
  <table>
    <thead><tr><th>Color</th><th>Status</th><th>Count</th></tr></thead>
    <tbody>
      <tr><td style="color: #22c55e">●</td><td>Implemented</td><td>207</td></tr>
      <tr><td style="color: #2ab4c8">●</td><td>Implementing</td><td>15</td></tr>
      <tr><td style="color: #f59e0b">●</td><td>Decided</td><td>10</td></tr>
      <tr><td style="color: #607888">●</td><td>Exploring</td><td>32</td></tr>
      <tr><td style="color: #405870">●</td><td>Seed / Deferred</td><td>18</td></tr>
    </tbody>
  </table>

  <p>For an interactive version with filtering, search, and node details, run <code>omegon serve</code> locally and open the web dashboard.</p>
</Docs>

<style>
  .graph-container {
    background: var(--card-bg);
    border: 1px solid var(--border-dim);
    border-radius: 8px;
    padding: 16px;
    margin: 24px 0;
    overflow: auto;
    max-height: 600px;
  }
  .graph-container :global(svg) {
    width: 100%;
    height: auto;
  }
  .graph-placeholder {
    color: var(--dim);
    text-align: center;
    padding: 48px;
  }
</style>
