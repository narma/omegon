direction: down

plan: Split Plan {
  style: { fill: "#0e2e20"; stroke: "#1ab878"; font-color: "#c4d8e4"; border-radius: 8 }
}

orchestrator: Orchestrator {
  style: { fill: "#1a4a6e"; stroke: "#2ab4c8"; font-color: "#c4d8e4"; border-radius: 8 }
}

children: Git Worktrees {
  style: {
    fill: "#06080e"
    stroke: "#1a3448"
    font-color: "#6ecad8"
    border-radius: 8
  }

  c1: child-1\nbranch: clv-auth {
    style: { fill: "#1a4a6e"; stroke: "#2ab4c8"; font-color: "#c4d8e4"; border-radius: 6 }
  }
  c2: child-2\nbranch: clv-api {
    style: { fill: "#1a4a6e"; stroke: "#2ab4c8"; font-color: "#c4d8e4"; border-radius: 6 }
  }
  c3: child-3\nbranch: clv-tests {
    style: { fill: "#1a3a5a"; stroke: "#1a8898"; font-color: "#c4d8e4"; border-radius: 6 }
  }
}

merge: Merge + Conflict Detection {
  style: { fill: "#2a1808"; stroke: "#c86418"; font-color: "#c4d8e4"; border-radius: 8 }
}

review: Adversarial Review {
  style: { fill: "#2a1010"; stroke: "#c83030"; font-color: "#c4d8e4"; border-radius: 8 }
}

result: Main Branch {
  style: { fill: "#0e2e20"; stroke: "#1ab878"; font-color: "#c4d8e4"; border-radius: 8 }
}

plan -> orchestrator: labels, scopes, deps {
  style: { stroke: "#1ab878"; font-color: "#c4d8e4" }
}

orchestrator -> children: dispatch waves {
  style: { stroke: "#2ab4c8"; font-color: "#c4d8e4" }
}

children.c3 -> children.c1: depends_on {
  style: { stroke: "#344858"; stroke-dash: 4; font-color: "#607888" }
}

children -> merge: completed branches {
  style: { stroke: "#2ab4c8"; font-color: "#c4d8e4" }
}

merge -> review: per-child check {
  style: { stroke: "#c86418"; font-color: "#c4d8e4" }
}

review -> result: pass {
  style: { stroke: "#1ab878"; font-color: "#c4d8e4" }
}
